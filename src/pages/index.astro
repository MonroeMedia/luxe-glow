---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import ServiceAreaStrip from '@components/ServiceAreaStrip.astro';
import PrepSection from '@components/PrepSection.astro';
import DayOfSection from '@components/DayOfSection.astro';
import PostTanSection from '@components/PostTanSection.astro';
import GallerySection from '@components/GallerySection.astro';
import WhyChooseUs from '@components/WhyChooseUs.astro';
import { getPageBySlug } from '@lib/queries';

const page = await getPageBySlug('home');
---

<BaseLayout
  title={page?.seo?.metaTitle ?? page?.title ?? 'Luxe Glow Spray Tans'}
  description={page?.seo?.metaDescription ?? 'Flawless, streak-free spray tans in Rutherfordton, NC and surrounding areas.'}
  seo={page?.seo}
>
  <Hero />
  <ServiceAreaStrip />
  <PrepSection />
  <DayOfSection />
  <PostTanSection />
  <GallerySection />
  <WhyChooseUs />
</BaseLayout>
