---
import type { DayOfBlock, SiteSettings } from '@lib/queries';

interface Props {
  block?: DayOfBlock | null;
  settings?: SiteSettings | null;
}

const { block, settings } = Astro.props;

const eyebrow    = block?.eyebrow    ?? 'Day of Appointment';
const heading    = block?.heading    ?? 'Arrive Ready to Glow';
const subtext    = block?.subtext    ?? 'On the day of your session, a little preparation goes a long way. Keep your skin completely barrier-free so the solution can do its job.';
const ctaLabel   = block?.ctaLabel   ?? settings?.ctaLabel ?? 'Book a Session';
const ctaDest    = block?.ctaDestination ?? settings?.ctaDestination ?? '/#contact';
const imageUrl   = block?.image?.asset?.url ?? null;
const imageAlt   = block?.image?.alt ?? 'Spray tan session preparation';

const defaultSteps = [
  {
    _key: 'barriers',
    num: '1',
    title: 'No Barriers on Skin',
    body: 'Arrive with clean product-free skin. Skip the lotion, perfume, deodorant, and makeup. Even lightweight products create a barrier that prevents the solution from bonding evenly — and no one wants a patchy tan.',
  },
  {
    _key: 'clothing',
    num: '2',
    title: 'Wear Loose Dark Clothing',
    body: 'Bring loose-fitting clothes to change into after your session. Tight clothing can cause the solution to rub, crease, or transfer before it sets. Dark fabrics are your best friend on spray tan day.',
  },
  {
    _key: 'undergarments',
    num: '3',
    title: 'Appropriate Undergarments',
    body: 'Wear or bring minimal undergarments for your session — a thong or swimsuit bottom works great. Full coverage during application leads to visible tan lines. Whatever you are comfortable with is what we will work with.',
  },
];

const steps = block?.steps?.length ? block.steps : defaultSteps;
---

<section id="dayof" class="dayof-section">
  <div class="dayof-ambient" aria-hidden="true"></div>

  <div class="dayof-inner" data-reveal>

    <div class="dayof-content">
      <p class="eyebrow">
        <span class="eyebrow-line" aria-hidden="true"></span>
        {eyebrow}
      </p>
      <h2>{heading}</h2>
      <p class="intro">{subtext}</p>

      <ol class="steps" role="list">
        {steps.map(({ num, title, body }) => (
          <li class="step">
            <span class="step-num" aria-hidden="true">{num}</span>
            <div class="step-text">
              <p class="step-title">{title}</p>
              <p class="step-body">{body}</p>
            </div>
          </li>
        ))}
      </ol>

      <a href={ctaDest} class="btn-primary dayof-cta">{ctaLabel}</a>
    </div>

    {imageUrl ? (
      <div class="dayof-image">
        <img src={imageUrl} alt={imageAlt} loading="lazy" />
      </div>
    ) : (
      <div class="dayof-image dayof-image--placeholder" role="img" aria-label="Spray tan session preparation — clean, product-free skin ready for application">
        <span class="image-label" aria-hidden="true">Photo Placeholder</span>
      </div>
    )}

  </div>
</section>

<style>
  .dayof-section {
    position: relative;
    overflow: hidden;
    background: #1C1C1C;
    padding: 100px 5%;
  }

  .dayof-ambient {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at top right, rgba(201, 168, 76, 0.07) 0%, transparent 60%);
    pointer-events: none;
  }

  .dayof-inner {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: center;
  }

  .eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-body);
    font-size: 10px;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 20px;
  }

  .eyebrow-line {
    display: block;
    width: 24px;
    height: 1px;
    background: var(--color-primary);
    flex-shrink: 0;
  }

  h2 {
    font-family: var(--font-display);
    font-size: clamp(30px, 4vw, 48px);
    color: var(--color-text);
    margin: 0 0 18px;
    font-weight: 700;
    line-height: 1.2;
  }

  .intro {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--color-muted);
    max-width: 560px;
    font-weight: 300;
    line-height: 1.8;
    margin: 0 0 44px;
  }

  .steps {
    display: flex;
    flex-direction: column;
    gap: 32px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .step {
    display: flex;
    gap: 24px;
    align-items: flex-start;
  }

  .step-num {
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    border: 1px solid var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-primary);
  }

  .step-title {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.5px;
    color: var(--color-text);
    margin: 0 0 6px;
  }

  .step-body {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-muted);
    line-height: 1.7;
    margin: 0;
  }

  .dayof-cta {
    display: inline-block;
    margin-top: 40px;
  }

  .dayof-image {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    border: 1px solid rgba(201, 168, 76, 0.3);
  }

  .dayof-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .dayof-image--placeholder {
    background: linear-gradient(160deg, #4A2E1A 0%, #1a0e06 60%, #111111 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .dayof-image--placeholder::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent 40%, rgba(201, 168, 76, 0.08) 50%, transparent 60%);
    pointer-events: none;
  }

  .image-label {
    position: absolute;
    top: 50%;
    left: 50%;
    translate: -50% -50%;
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(201, 168, 76, 0.4);
    white-space: nowrap;
    z-index: 1;
  }

  @media (max-width: 900px) {
    .dayof-inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .dayof-content { order: 1; }

    .dayof-image {
      order: 2;
      aspect-ratio: 16 / 9;
    }
  }

  @media (max-width: 600px) {
    .dayof-section { padding: 64px 5%; }

    .dayof-cta {
      width: 100%;
      text-align: center;
    }
  }
</style>
