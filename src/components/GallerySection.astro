---
import type { GalleryBlock, SiteSettings } from '@lib/queries';

interface Props {
  block?: GalleryBlock | null;
  settings?: SiteSettings | null;
}

const { block, settings } = Astro.props;

const eyebrow  = block?.eyebrow  ?? 'Results';
const heading  = block?.heading  ?? 'The Glow Speaks for Itself';
const subtext  = block?.subtext  ?? 'Real results from real clients. No filter, no fake orange — just rich natural-looking bronze that complements every skin tone.';
const ctaLabel = block?.ctaLabel ?? settings?.ctaLabel ?? 'Book a Session';
const ctaDest  = block?.ctaDestination ?? settings?.ctaDestination ?? '/#contact';
const images   = block?.images?.length ? block.images : [];
const placeholderCount = Math.max(0, 3 - images.length);
---

<section id="results" class="gallery-section">
  <div class="gallery-inner" data-reveal>

    <div class="gallery-header">
      <p class="eyebrow">
        <span class="eyebrow-line" aria-hidden="true"></span>
        {eyebrow}
        <span class="eyebrow-line" aria-hidden="true"></span>
      </p>
      <h2>{heading}</h2>
      <p class="subtext">{subtext}</p>
    </div>

    <div class="gallery-grid">
      {images.map(({ image, altText }, i) => (
        <div class="gallery-card" role="img" aria-label={altText ?? `Before and after spray tan result — client ${i + 1}`}>
          {image?.asset?.url && (
            <img src={image.asset.url} alt={altText ?? `Spray tan result ${i + 1}`} loading="lazy" />
          )}
          <div class="card-tags" aria-hidden="true">
            <span class="tag tag-before">Before</span>
            <span class="tag tag-after">After</span>
          </div>
        </div>
      ))}
      {Array.from({ length: placeholderCount }).map((_, i) => (
        <div class="gallery-card gallery-card--placeholder" role="img" aria-label={`Before and after spray tan result — client ${images.length + i + 1}`}>
          <div class="card-sheen" aria-hidden="true"></div>
          <span class="card-placeholder" aria-hidden="true">Client Photo</span>
          <div class="card-tags" aria-hidden="true">
            <span class="tag tag-before">Before</span>
            <span class="tag tag-after">After</span>
          </div>
        </div>
      ))}
    </div>

    <div class="gallery-cta">
      <a href={ctaDest} class="btn-primary">{ctaLabel}</a>
    </div>

  </div>
</section>

<style>
  .gallery-section {
    background: #111111;
    padding: 100px 5%;
  }

  .gallery-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .gallery-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .eyebrow {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 12px;
    font-family: var(--font-body);
    font-size: 10px;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 20px;
  }

  .eyebrow-line {
    display: block;
    width: 24px;
    height: 1px;
    background: var(--color-primary);
    flex-shrink: 0;
  }

  h2 {
    font-family: var(--font-display);
    font-size: clamp(30px, 4vw, 48px);
    color: var(--color-text);
    margin: 0 0 18px;
    font-weight: 700;
    line-height: 1.2;
  }

  .subtext {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--color-muted);
    max-width: 560px;
    margin: 0 auto;
    font-weight: 300;
    line-height: 1.8;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }

  .gallery-card {
    aspect-ratio: 3 / 4;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding: 20px;
    border: 1px solid rgba(201, 168, 76, 0.3);
  }

  .gallery-card img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .gallery-card--placeholder {
    background: linear-gradient(180deg, #4A2E1A 0%, #2a1508 100%);
  }

  .card-sheen {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent 40%, rgba(201, 168, 76, 0.08) 50%, transparent 60%);
    pointer-events: none;
  }

  .card-placeholder {
    position: absolute;
    top: 50%;
    left: 50%;
    translate: -50% -50%;
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(201, 168, 76, 0.3);
    white-space: nowrap;
  }

  .card-tags {
    display: flex;
    width: 100%;
    gap: 2px;
    position: relative;
    z-index: 1;
  }

  .tag {
    flex: 1;
    text-align: center;
    font-family: var(--font-body);
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    font-weight: 600;
    padding: 8px 0;
  }

  .tag-before {
    background: rgba(0, 0, 0, 0.7);
    color: var(--color-muted);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .tag-after {
    background: rgba(201, 168, 76, 0.2);
    color: var(--color-primary);
    border: 1px solid rgba(201, 168, 76, 0.3);
  }

  .gallery-cta {
    text-align: center;
    margin-top: 48px;
  }

  @media (max-width: 900px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .gallery-section { padding: 64px 5%; }
    .gallery-grid { grid-template-columns: 1fr; }
  }
</style>
