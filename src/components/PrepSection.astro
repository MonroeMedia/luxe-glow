---
import type { PrepBlock } from '@lib/queries';

interface Props {
  block?: PrepBlock | null;
}

const { block } = Astro.props;

const eyebrow     = block?.eyebrow     ?? 'Preparation';
const heading     = block?.heading     ?? 'Before Your Appointment';
const subtext     = block?.subtext     ?? 'The secret to a flawless, long-lasting tan starts at least 24 hours before you walk in. Follow these three steps and your results will speak for themselves.';
const calloutLabel = block?.calloutLabel ?? 'Important:';
const calloutText  = block?.calloutText  ?? 'All three of these steps should be completed at least 24 hours before your appointment — not the morning of. Day-of barriers on the skin affect how the solution adheres.';

const defaultCards = [
  {
    _key: 'shave',
    num: '01',
    title: 'Shave',
    body: 'Shave at least 24 hours prior to your appointment. Shaving immediately before can open pores and cause the solution to appear patchy or uneven. Giving your skin time to settle ensures a smooth, even canvas.',
  },
  {
    _key: 'exfoliate',
    num: '02',
    title: 'Exfoliate',
    body: 'Use a gentle body scrub or exfoliating mitt to remove dead skin cells — paying extra attention to rough areas like elbows, knees, and ankles. This step is the single biggest factor in how evenly your tan develops and how long it lasts.',
  },
  {
    _key: 'moisturize',
    num: '03',
    title: 'Moisturize',
    body: 'After exfoliating, apply a lightweight oil-free moisturizer to any dry or rough patches. Hydrated skin absorbs the solution more evenly. Do this the night before — not day-of — so no residue interferes with your tan.',
  },
];

const cards = block?.cards?.length ? block.cards : defaultCards;
---

<section id="prep" class="prep-section">
  <div class="prep-inner" data-reveal>

    <div class="prep-header">
      <p class="eyebrow">
        <span class="eyebrow-line" aria-hidden="true"></span>
        {eyebrow}
      </p>
      <h2>{heading}</h2>
      <p class="subtext">{subtext}</p>
    </div>

    <div class="cards-grid">
      {cards.map(({ num, title, body }) => (
        <div class="card">
          <span class="card-num" aria-hidden="true">{num}</span>
          <h3 class="card-title">{title}</h3>
          <p class="card-body">{body}</p>
        </div>
      ))}
    </div>

    <aside class="callout">
      <p>
        <strong>{calloutLabel}</strong> {calloutText}
      </p>
    </aside>

  </div>
</section>

<style>
  .prep-section {
    background: #111111;
    padding: 100px 5%;
  }

  .prep-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .prep-header {
    margin-bottom: 60px;
  }

  .eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-body);
    font-size: 10px;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 20px;
  }

  .eyebrow-line {
    display: block;
    width: 24px;
    height: 1px;
    background: var(--color-primary);
    flex-shrink: 0;
  }

  h2 {
    font-family: var(--font-display);
    font-size: clamp(30px, 4vw, 48px);
    color: var(--color-text);
    margin: 0 0 18px;
    font-weight: 700;
    line-height: 1.2;
  }

  .subtext {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--color-muted);
    max-width: 560px;
    font-weight: 300;
    line-height: 1.8;
    margin: 0;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }

  .card {
    position: relative;
    background: var(--color-surface);
    border: 1px solid rgba(201, 168, 76, 0.3);
    padding: 48px 36px;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(201, 168, 76, 0.1);
    border-color: rgba(201, 168, 76, 0.6);
  }

  .card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(to right, transparent, var(--color-primary), transparent);
  }

  .card-num {
    display: block;
    font-family: var(--font-display);
    font-size: 52px;
    color: rgba(201, 168, 76, 0.12);
    line-height: 1;
    margin-bottom: 24px;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 18px;
    color: var(--color-text);
    letter-spacing: 0.5px;
    margin: 0 0 12px;
    font-weight: 700;
  }

  .card-body {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-muted);
    line-height: 1.8;
    margin: 0;
  }

  .callout {
    border-left: 3px solid var(--color-primary);
    background: rgba(201, 168, 76, 0.04);
    padding: 24px 32px;
    margin-top: 40px;
  }

  .callout p {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-muted);
    font-style: italic;
    line-height: 1.8;
    margin: 0;
  }

  .callout strong {
    color: var(--color-primary);
    font-style: normal;
    font-weight: 500;
  }

  @media (max-width: 900px) {
    .cards-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .cards-grid { grid-template-columns: 1fr; }
  }
</style>
