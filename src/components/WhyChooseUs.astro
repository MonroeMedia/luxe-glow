---
import type { WhyChooseUsBlock } from '@lib/queries';

interface Props {
  block?: WhyChooseUsBlock | null;
}

const { block } = Astro.props;

const eyebrow       = block?.eyebrow       ?? 'Why Luxe Glow';
const heading       = block?.heading       ?? 'The Difference Is in the Details';
const subtext       = block?.subtext       ?? 'We take spray tanning seriously. From the formula we use to the way we move through your appointment, every detail is designed to give you a result you are proud to show off.';
const calloutBadge  = block?.calloutBadge  ?? 'Our Promise';
const calloutHeading = block?.calloutHeading ?? 'Our Formulas Will Never Pull Orange';
const calloutBody   = block?.calloutBody   ?? 'The orange tan era is over. Every solution we use is carefully selected for its ability to develop into a rich warm bronze across all skin tones — never brassy, never artificial. If you have been burned by an orange tan before, this is your sign to try again.';

const defaultCards = [
  {
    _key: 'mobile',
    title: 'We Come to You',
    body: 'Our mobile spray tan service brings the studio experience directly to your home. No driving, no waiting, no rushing. Book a session on your schedule in your space.',
  },
  {
    _key: 'tone',
    title: 'Expert Eye for Tone',
    body: 'Not all tans are created equal. We assess your natural skin tone, undertones, and desired depth before ever picking up the spray gun — so your result looks like you just got back from vacation, not a costume.',
  },
  {
    _key: 'comfort',
    title: 'A Comfortable Experience',
    body: 'We know spray tanning can feel vulnerable. Luxe Glow is built on professionalism and a welcoming presence. First-timers and regulars alike leave feeling confident, not awkward.',
  },
];

const cards = block?.cards?.length ? block.cards : defaultCards;
---

<section id="why" class="why-section">
  <div class="why-inner" data-reveal>

    <div class="why-header">
      <p class="eyebrow">
        <span class="eyebrow-line" aria-hidden="true"></span>
        {eyebrow}
      </p>
      <h2>{heading}</h2>
      <p class="subtext">{subtext}</p>
    </div>

    <div class="cards-grid">
      {cards.map(({ title, body }) => (
        <div class="card">
          <span class="card-icon" aria-hidden="true">✦</span>
          <h3 class="card-heading">{title}</h3>
          <p class="card-body">{body}</p>
        </div>
      ))}
    </div>

    <div class="callout">
      <div class="callout-badge">{calloutBadge}</div>
      <div class="callout-text">
        <h3 class="callout-heading">{calloutHeading}</h3>
        <p class="callout-body">{calloutBody}</p>
      </div>
    </div>

  </div>
</section>

<style>
  .why-section {
    background: #0A0A0A;
    padding: 100px 5%;
  }

  .why-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .why-header {
    margin-bottom: 60px;
  }

  .eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-body);
    font-size: 10px;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 20px;
  }

  .eyebrow-line {
    display: block;
    width: 24px;
    height: 1px;
    background: var(--color-primary);
    flex-shrink: 0;
  }

  h2 {
    font-family: var(--font-display);
    font-size: clamp(30px, 4vw, 48px);
    color: var(--color-text);
    margin: 0 0 18px;
    font-weight: 700;
    line-height: 1.2;
  }

  .subtext {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--color-muted);
    max-width: 560px;
    font-weight: 300;
    line-height: 1.8;
    margin: 0;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-bottom: 2px;
  }

  .card {
    background: #161616;
    border: 1px solid rgba(201, 168, 76, 0.3);
    padding: 44px 36px;
    transition: border-color 0.3s ease, background 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
  }

  .card:hover {
    border-color: var(--color-primary);
    background: rgba(201, 168, 76, 0.04);
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(201, 168, 76, 0.1);
  }

  .card-icon {
    display: block;
    font-size: 24px;
    color: var(--color-primary);
    margin-bottom: 24px;
    line-height: 1;
    transition: transform 0.4s ease;
  }

  .card:hover .card-icon {
    transform: rotate(45deg) scale(1.1);
  }

  .card-heading {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.5px;
    color: var(--color-text);
    margin: 0 0 12px;
  }

  .card-body {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-muted);
    line-height: 1.8;
    margin: 0;
  }

  .callout {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #4A2E1A 0%, #1a0e06 100%);
    border: 1px solid var(--color-primary);
    padding: 48px 44px;
    display: flex;
    align-items: center;
    gap: 48px;
  }

  .callout::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 4px;
    background: linear-gradient(to bottom, transparent, var(--color-primary), transparent);
  }

  .callout-badge {
    background: rgba(201, 168, 76, 0.12);
    border: 1px solid var(--color-primary);
    padding: 12px 20px;
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--color-primary);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .callout-heading {
    font-family: var(--font-display);
    font-size: 26px;
    color: var(--color-text);
    margin: 0 0 12px;
    font-weight: 700;
    line-height: 1.2;
  }

  .callout-body {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--color-muted);
    max-width: 560px;
    line-height: 1.8;
    margin: 0;
  }

  @media (max-width: 900px) {
    .cards-grid { grid-template-columns: 1fr; }

    .callout {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
      padding: 36px 28px;
    }
  }
</style>
