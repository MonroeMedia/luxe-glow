---
import type { SiteSettings } from '@lib/queries';

interface Props {
  settings?: SiteSettings | null;
}

const { settings } = Astro.props;

const logoText = settings?.logoText ?? 'LUXE GLOW';
const ctaLabel = settings?.ctaLabel ?? 'Book a Session';
const ctaDestination = settings?.ctaDestination ?? '/#contact';
const facebookUrl = settings?.social?.facebook ?? 'https://www.facebook.com/profile.php?id=61582413587028';

const links = [
  { label: 'Home',    href: '/'         },
  { label: 'Prep',    href: '/#prep'    },
  { label: 'Results', href: '/#results' },
  { label: 'Why Us',  href: '/#why'     },
  { label: 'Contact', href: '/#contact' },
];

// Split logoText for the two-tone effect (first word plain, rest gold)
const [logoFirst, ...logoRest] = logoText.split(' ');
const logoGold = logoRest.join(' ');
---

<header class="site-header">
  <nav aria-label="Main navigation">

    <!-- Logo -->
    <a href="/" class="site-logo" aria-label={`${logoText} — home`}>
      {logoFirst}{logoGold && <Fragment>&nbsp;<span class="logo-glow">{logoGold}</span></Fragment>}
    </a>

    <!-- Desktop links -->
    <ul id="nav-menu" class="nav-links" role="list">
      {links.map(({ label, href }) => (
        <li><a href={href}>{label}</a></li>
      ))}
    </ul>

    <!-- Desktop right side -->
    <div class="nav-right">
      <div class="nav-social">
        <a href={facebookUrl} aria-label="Facebook" class="social-link" target={facebookUrl !== '#' ? '_blank' : undefined} rel={facebookUrl !== '#' ? 'noopener noreferrer' : undefined}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
        </a>
      </div>

      <a href={ctaDestination} class="btn-outline nav-cta">{ctaLabel}</a>
    </div>

    <!-- Hamburger -->
    <button
      class="nav-toggle"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Toggle navigation"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
    <ul role="list">
      {links.map(({ label, href }) => (
        <li><a href={href} class="mobile-link">{label}</a></li>
      ))}
    </ul>
    <a href={ctaDestination} class="btn-outline mobile-cta">{ctaLabel}</a>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background-color: rgba(10, 10, 10, 0.88);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(201, 168, 76, 0.2);
    transition: background-color 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
  }

  .site-header.scrolled {
    background-color: rgba(5, 5, 5, 0.97);
    border-bottom-color: rgba(201, 168, 76, 0.3);
    box-shadow: 0 1px 40px rgba(0, 0, 0, 0.5);
  }

  nav {
    display: flex;
    align-items: center;
    height: 72px;
    padding: 0 5%;
    gap: 2rem;
  }

  /* Logo */
  .site-logo {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-right: auto;
  }

  .logo-glow {
    color: var(--color-primary);
  }

  /* Desktop nav links */
  .nav-links {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 2rem;
  }

  .nav-links a {
    font-family: var(--font-body);
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-muted);
    transition: color var(--transition);
  }

  .nav-links a:hover {
    color: var(--color-primary);
  }

  /* Right side */
  .nav-right {
    display: none;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-social {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .social-link {
    font-size: 13px;
    color: var(--color-muted);
    transition: color var(--transition);
    display: flex;
    align-items: center;
  }

  .social-link:hover {
    color: var(--color-primary);
  }

  .nav-cta {
    white-space: nowrap;
    padding: 10px 24px;
    font-size: 11px;
    letter-spacing: 3px;
  }

  /* Hamburger */
  .nav-toggle {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    margin-left: auto;
    min-width: 44px;
    min-height: 44px;
  }

  .nav-toggle span {
    display: block;
    width: 22px;
    height: 1.5px;
    background-color: var(--color-primary);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .nav-toggle[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }

  .nav-toggle[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }

  .nav-toggle[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* Mobile menu */
  .mobile-menu {
    display: none;
    flex-direction: column;
    background-color: var(--color-surface);
    border-top: 1px solid rgba(201, 168, 76, 0.15);
    padding: 2rem 5%;
    width: 100%;
    gap: 0;
  }

  .mobile-menu[aria-hidden="false"] {
    display: flex;
  }

  .mobile-menu ul {
    list-style: none;
    margin: 0 0 2rem 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .mobile-link {
    display: block;
    padding: 1rem 0;
    font-family: var(--font-body);
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-muted);
    border-bottom: 1px solid rgba(201, 168, 76, 0.1);
    transition: color var(--transition);
  }

  .mobile-link:hover {
    color: var(--color-primary);
  }

  .mobile-cta {
    align-self: flex-start;
    margin-top: 0.5rem;
  }

  @media (max-width: 480px) {
    .mobile-cta {
      align-self: stretch;
      text-align: center;
    }
  }

  /* Desktop breakpoint */
  @media (min-width: 900px) {
    .nav-links {
      display: flex;
    }

    .nav-right {
      display: flex;
    }

    .nav-toggle {
      display: none;
    }

    .mobile-menu {
      display: none !important;
    }
  }
</style>

<script>
  const toggle = document.querySelector('.nav-toggle') as HTMLButtonElement | null;
  const mobileMenu = document.getElementById('mobile-menu') as HTMLDivElement | null;
  const header = document.querySelector('.site-header') as HTMLElement | null;

  if (toggle && mobileMenu) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      mobileMenu.setAttribute('aria-hidden', String(expanded));
    });

    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        mobileMenu.setAttribute('aria-hidden', 'true');
      });
    });
  }

  if (header) {
    const onScroll = () => header.classList.toggle('scrolled', window.scrollY > 48);
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
