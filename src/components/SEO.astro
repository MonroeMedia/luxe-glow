---
import type { SEOFields, SiteSettings } from '@lib/queries';

interface Props {
  seo?: SEOFields;
  title?: string;
  description?: string;
  settings?: SiteSettings | null;
  canonicalUrl?: string;
}

const {
  seo,
  title: propTitle,
  description: propDescription,
  settings,
  canonicalUrl,
} = Astro.props;

const siteName = settings?.businessName ?? 'Luxe Glow Spray Tans';
const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? Astro.url.origin;

const metaTitle = seo?.metaTitle ?? propTitle ?? siteName;
const metaDescription = seo?.metaDescription ?? propDescription ?? '';
const ogImageUrl = seo?.ogImage?.asset?.url ?? `${siteUrl}/og-image.png`;
const ogImageAlt = seo?.ogImage?.alt ?? 'Luxe Glow Spray Tans — Rutherfordton, NC';
const noIndex = seo?.noIndex ?? false;
const canonical = canonicalUrl ?? Astro.url.href;

// Resolve schema markup — either a raw JSON string from Sanity or null
let schemaJson: string | null = null;
if (seo?.schemaMarkup) {
  try {
    JSON.parse(seo.schemaMarkup);
    schemaJson = seo.schemaMarkup;
  } catch {
    // Skip invalid schema
  }
}
---

<!-- Primary meta -->
<title>{metaTitle}</title>
<meta name="description" content={metaDescription} />
<link rel="canonical" href={canonical} />
<meta name="robots" content={noIndex ? 'noindex, nofollow' : 'index, follow'} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:locale" content="en_US" />
<meta property="og:site_name" content={siteName} />
<meta property="og:title" content={metaTitle} />
<meta property="og:description" content={metaDescription} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={ogImageAlt} />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={metaTitle} />
<meta name="twitter:description" content={metaDescription} />
<meta name="twitter:image" content={ogImageUrl} />
<meta name="twitter:image:alt" content={ogImageAlt} />

<!-- JSON-LD Schema -->
{schemaJson && (
  <script type="application/ld+json" set:html={schemaJson} />
)}
