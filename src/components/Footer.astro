---
import type { SiteSettings } from '@lib/queries';

interface Props {
  settings?: SiteSettings | null;
}

const { settings } = Astro.props;

const year = new Date().getFullYear();

const navLinks = [
  { label: 'Home',       href: '/'         },
  { label: 'Prep Guide', href: '/#prep'    },
  { label: 'Results',    href: '/#results' },
  { label: 'Why Us',     href: '/#why'     },
  { label: 'Book',       href: '/#contact' },
];

const serviceAreas = [
  'Rutherfordton',
  'Spindale',
  'Forest City',
  'Lake Lure',
  'Tryon',
  'Morganton',
];
---

<footer class="site-footer">
  <div class="footer-inner">

    <!-- Grid -->
    <div class="footer-grid">

      <!-- Col 1 — Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          LUXE <span class="logo-glow">GLOW</span>
        </a>
        <p class="footer-desc">
          Premium spray tans and mobile spray tan services in Rutherfordton,
          NC and surrounding areas. Flawless, natural-looking color — every time.
        </p>
      </div>

      <!-- Col 2 — Navigate -->
      <div class="footer-col">
        <p class="col-label">Navigate</p>
        <ul class="col-list" role="list">
          {navLinks.map(({ label, href }) => (
            <li><a href={href}>{label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Col 3 — Service Areas -->
      <div class="footer-col">
        <p class="col-label">Service Areas</p>
        <ul class="col-list col-list--text" role="list">
          {serviceAreas.map((area) => (
            <li>{area}</li>
          ))}
        </ul>
      </div>

      <!-- Col 4 — Contact -->
      <div class="footer-col">
        <p class="col-label">Contact</p>
        <ul class="col-list" role="list">
          <li><a href="tel:8284294759">(828) 429-4759</a></li>
          <li><a href="#">Instagram</a></li>
          <li><a href="#">Facebook</a></li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p class="footer-copy">&copy; {year} Luxe Glow. All rights reserved.</p>
      <div class="footer-social">
        <a href="#">Instagram</a>
        <a href="#">Facebook</a>
      </div>
    </div>

  </div>
</footer>

<style>
  .site-footer {
    background: #0A0A0A;
    border-top: 1px solid rgba(201, 168, 76, 0.3);
    padding: 60px 5% 40px;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Grid */
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 48px;
    margin-bottom: 48px;
  }

  /* Col 1 — Brand */
  .footer-logo {
    display: block;
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--color-text);
    text-decoration: none;
    margin-bottom: 16px;
    transition: none;
  }

  .footer-logo:hover {
    color: var(--color-text);
  }

  .logo-glow {
    color: var(--color-primary);
  }

  .footer-desc {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-muted);
    line-height: 1.7;
    max-width: 280px;
    margin: 0;
  }

  /* Column label */
  .col-label {
    font-family: var(--font-body);
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--color-primary);
    margin: 0 0 20px;
  }

  /* Column link lists */
  .col-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .col-list a {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .col-list a:hover {
    color: var(--color-primary);
  }

  /* Plain text items (service areas) */
  .col-list--text li {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-muted);
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid rgba(201, 168, 76, 0.3);
    padding-top: 28px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }

  .footer-copy {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-muted);
    margin: 0;
  }

  .footer-social {
    display: flex;
    gap: 20px;
  }

  .footer-social a {
    font-family: var(--font-body);
    font-size: 12px;
    letter-spacing: 1px;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-social a:hover {
    color: var(--color-primary);
  }

  /* Tablet */
  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }

    .footer-desc {
      max-width: 100%;
    }
  }

  /* Mobile */
  @media (max-width: 600px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
</style>
