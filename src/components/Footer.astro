---
import type { SiteSettings } from '@lib/queries';

interface Props {
  settings?: SiteSettings | null;
}

const { settings } = Astro.props;
const year = new Date().getFullYear();
const businessName = settings?.businessName ?? 'Luxe Glow Spray Tans';
---

<footer class="site-footer">
  <!-- Top gold gradient line -->
  <div class="footer-top-line" aria-hidden="true"></div>

  <div class="footer-inner">

    <!-- Brand column -->
    <div class="footer-brand">
      <a href="/" class="footer-logo" aria-label="Luxe Glow — home">
        LUXE <span>GLOW</span>
      </a>
      <p class="footer-tagline">Spray Tans · Rutherfordton, NC</p>

      <div class="footer-contacts">
        {settings?.phone && (
          <a href={`tel:${settings.phone.replace(/\D/g, '')}`} class="footer-contact-link">
            {settings.phone}
          </a>
        )}
        {settings?.email && (
          <a href={`mailto:${settings.email}`} class="footer-contact-link">
            {settings.email}
          </a>
        )}
        {settings?.address && (
          <p class="footer-address">{settings.address}</p>
        )}
      </div>
    </div>

    <!-- Service areas column -->
    {settings?.serviceAreas && settings.serviceAreas.length > 0 && (
      <div class="footer-col">
        <p class="footer-col-label">Service Areas</p>
        <ul class="footer-areas-list" role="list">
          {settings.serviceAreas.map((area: string) => (
            <li>{area}</li>
          ))}
        </ul>
      </div>
    )}

    <!-- Navigation column -->
    <div class="footer-col">
      <p class="footer-col-label">Navigate</p>
      <ul class="footer-nav-list" role="list">
        <li><a href="/#home">Home</a></li>
        <li><a href="/#prep">Preparation</a></li>
        <li><a href="/#results">Results</a></li>
        <li><a href="/#why">Why Us</a></li>
        <li><a href="/#contact">Book a Session</a></li>
      </ul>

      {settings?.social && (settings.social.instagram || settings.social.facebook) && (
        <div class="footer-social">
          {settings.social.instagram && (
            <a href={settings.social.instagram} target="_blank" rel="noopener noreferrer">
              Instagram
            </a>
          )}
          {settings.social.facebook && (
            <a href={settings.social.facebook} target="_blank" rel="noopener noreferrer">
              Facebook
            </a>
          )}
        </div>
      )}
    </div>

  </div>

  <!-- Legal strip -->
  <div class="footer-legal">
    <div class="footer-legal-inner">
      <p>&copy; {year} {businessName}. All rights reserved.</p>
      <p class="footer-domain">luxeglowtanning.com</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: #0D0D0D;
    color: var(--color-muted);
  }

  .footer-top-line {
    height: 1px;
    background: linear-gradient(to right, transparent, var(--color-primary), transparent);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 3rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 72px 5% 56px;
  }

  /* Logo */
  .footer-logo {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: 3px;
    text-transform: uppercase;
    display: inline-block;
    margin-bottom: 8px;
    transition: none;
  }

  .footer-logo span {
    color: var(--color-primary);
  }

  .footer-tagline {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--color-muted);
    margin: 0 0 28px;
  }

  .footer-contacts {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .footer-contact-link {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-muted);
    transition: color var(--transition);
  }

  .footer-contact-link:hover {
    color: var(--color-primary);
  }

  .footer-address {
    font-family: var(--font-body);
    font-size: 13px;
    color: rgba(168, 152, 128, 0.6);
    margin: 8px 0 0;
    line-height: 1.5;
  }

  /* Columns */
  .footer-col-label {
    font-family: var(--font-body);
    font-size: 10px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--color-primary);
    font-weight: 500;
    margin: 0 0 20px;
  }

  .footer-areas-list,
  .footer-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-areas-list li {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-muted);
  }

  .footer-nav-list li a {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-muted);
    transition: color var(--transition);
  }

  .footer-nav-list li a:hover {
    color: var(--color-text);
  }

  /* Social */
  .footer-social {
    display: flex;
    gap: 20px;
    margin-top: 28px;
    padding-top: 20px;
    border-top: 1px solid rgba(201, 168, 76, 0.15);
  }

  .footer-social a {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-primary);
    font-weight: 500;
    transition: color var(--transition);
  }

  .footer-social a:hover {
    color: var(--color-accent);
  }

  /* Legal */
  .footer-legal {
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .footer-legal-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px 5%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .footer-legal-inner p {
    font-family: var(--font-body);
    font-size: 12px;
    color: rgba(168, 152, 128, 0.45);
    margin: 0;
  }

  .footer-domain {
    letter-spacing: 1px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
      padding: 56px 5% 48px;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
