---
import type { SiteSettings } from '@lib/queries';

interface Props {
  settings?: SiteSettings | null;
}

const { settings } = Astro.props;

const year           = new Date().getFullYear();
const logoText       = settings?.logoText ?? 'LUXE GLOW';
const phone          = settings?.phone ?? '(828) 429-4759';
const phoneRaw       = phone.replace(/\D/g, '');
const instagramUrl   = settings?.social?.instagram ?? '#';
const facebookUrl    = settings?.social?.facebook ?? '#';
const serviceAreas   = settings?.serviceAreas?.length
  ? settings.serviceAreas
  : ['Rutherfordton', 'Spindale', 'Forest City', 'Lake Lure', 'Tryon', 'Morganton'];
const copyrightText  = settings?.copyrightText ?? `© ${year} Luxe Glow. All rights reserved.`;
const city           = settings?.city ?? 'Rutherfordton';
const state          = settings?.state ?? 'NC';

// Split logo text for two-tone effect
const [logoFirst, ...logoRest] = logoText.split(' ');
const logoGold = logoRest.join(' ');

const navLinks = [
  { label: 'Home',       href: '/'         },
  { label: 'Prep Guide', href: '/#prep'    },
  { label: 'Results',    href: '/#results' },
  { label: 'Why Us',     href: '/#why'     },
  { label: 'Book',       href: '/#contact' },
];
---

<footer class="site-footer">
  <div class="footer-inner">

    <div class="footer-grid">

      <!-- Col 1 — Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          {logoFirst}{logoGold && <Fragment>&nbsp;<span class="logo-glow">{logoGold}</span></Fragment>}
        </a>
        <p class="footer-desc">
          Premium spray tans and mobile spray tan services in {city},
          {state} and surrounding areas. Flawless, natural-looking color — every time.
        </p>
      </div>

      <!-- Col 2 — Navigate -->
      <div class="footer-col">
        <p class="col-label">Navigate</p>
        <ul class="col-list" role="list">
          {navLinks.map(({ label, href }) => (
            <li><a href={href}>{label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Col 3 — Service Areas -->
      <div class="footer-col">
        <p class="col-label">Service Areas</p>
        <ul class="col-list col-list--text" role="list">
          {serviceAreas.map((area) => (
            <li>{area}</li>
          ))}
        </ul>
      </div>

      <!-- Col 4 — Contact -->
      <div class="footer-col">
        <p class="col-label">Contact</p>
        <ul class="col-list" role="list">
          <li><a href={`tel:${phoneRaw}`}>{phone}</a></li>
          {instagramUrl !== '#' && <li><a href={instagramUrl} target="_blank" rel="noopener noreferrer">Instagram</a></li>}
          {instagramUrl === '#' && <li><a href="#">Instagram</a></li>}
          {facebookUrl !== '#' && <li><a href={facebookUrl} target="_blank" rel="noopener noreferrer">Facebook</a></li>}
          {facebookUrl === '#' && <li><a href="#">Facebook</a></li>}
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p class="footer-copy">{copyrightText}</p>
      <div class="footer-social">
        <a href={instagramUrl} target={instagramUrl !== '#' ? '_blank' : undefined} rel={instagramUrl !== '#' ? 'noopener noreferrer' : undefined}>Instagram</a>
        <a href={facebookUrl} target={facebookUrl !== '#' ? '_blank' : undefined} rel={facebookUrl !== '#' ? 'noopener noreferrer' : undefined}>Facebook</a>
      </div>
    </div>

  </div>
</footer>

<style>
  .site-footer {
    background: #0A0A0A;
    border-top: 1px solid rgba(201, 168, 76, 0.3);
    padding: 60px 5% 40px;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 48px;
    margin-bottom: 48px;
  }

  .footer-logo {
    display: block;
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--color-text);
    text-decoration: none;
    margin-bottom: 16px;
    transition: none;
  }

  .footer-logo:hover {
    color: var(--color-text);
  }

  .logo-glow {
    color: var(--color-primary);
  }

  .footer-desc {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-muted);
    line-height: 1.7;
    max-width: 280px;
    margin: 0;
  }

  .col-label {
    font-family: var(--font-body);
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--color-primary);
    margin: 0 0 20px;
  }

  .col-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .col-list a {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .col-list a:hover {
    color: var(--color-primary);
  }

  .col-list--text li {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-muted);
  }

  .footer-bottom {
    border-top: 1px solid rgba(201, 168, 76, 0.3);
    padding-top: 28px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }

  .footer-copy {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-muted);
    margin: 0;
  }

  .footer-social {
    display: flex;
    gap: 20px;
  }

  .footer-social a {
    font-family: var(--font-body);
    font-size: 12px;
    letter-spacing: 1px;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-social a:hover {
    color: var(--color-primary);
  }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }

    .footer-desc {
      max-width: 100%;
    }
  }

  @media (max-width: 600px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
</style>
